# ============================================================
# Fichier .env.example – Variables d'environnement
# IMPORTANT : Copiez ce fichier en .env et ne le commitez JAMAIS
# Commande : cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# SÉCURITÉ DJANGO
# ----------------------------------------------------------
# Clé secrète Django – Générez-en une nouvelle avec :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-changez-cette-cle-en-production-!abc123xyz

# Mode debug – False en production !
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
# Exemple production : monsite.com,www.monsite.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------
# BASE DE DONNÉES
# ----------------------------------------------------------
# SQLite (défaut – aucune configuration nécessaire)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (exemple pour la production)
# DATABASE_URL=postgresql://utilisateur:motdepasse@localhost:5432/transport_db

# MySQL (exemple)
# DATABASE_URL=mysql://utilisateur:motdepasse@localhost:3306/transport_db

# ----------------------------------------------------------
# INTERNATIONALISATION
# ----------------------------------------------------------
LANGUAGE_CODE=fr-fr
TIME_ZONE=Africa/Dakar

# ----------------------------------------------------------
# FICHIERS STATIQUES ET MÉDIAS (production)
# ----------------------------------------------------------
# STATIC_ROOT=/var/www/transport/staticfiles/
# MEDIA_ROOT=/var/www/transport/media/

# ----------------------------------------------------------
# EMAIL (pour les notifications futures)
# ----------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=votre@email.com
# EMAIL_HOST_PASSWORD=votre_mot_de_passe_application

# ----------------------------------------------------------
# PARAMÈTRES ADDITIONNELS
# ----------------------------------------------------------
# Durée de session en secondes (86400 = 24h)
# SESSION_COOKIE_AGE=86400
